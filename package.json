{
  "name": "agent-cooper",
  "version": "1.0.0",
  "description": "Automated home monitoring powered by Azure Functions",
  "main": "dist/src/functions/*.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsc",
    "watch": "tsc -w",
    "prestart": "npm run build",
    "start": "func start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:pre-deploy": "vitest run tests/integration/pre-deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@azure/functions": "^4.8.0",
    "nodemailer": "^8.0.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "yaml": "^2.8.3"
  }
}
